<Window x:Class="CyberThrust.IRIS.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:CyberThrust.IRIS.App.Views"
        Title="CyberThrust.IRIS — Incident Response &amp; Investigation Suite"
        Icon="Assets/iris.ico"
        Width="1440" Height="900"
        MinWidth="1100" MinHeight="700"
        Background="{DynamicResource Brush.Bg0}"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable, Segoe UI">
    <Window.InputBindings>
        <KeyBinding Modifiers="Ctrl" Key="D1" Command="{Binding NavCommand}" CommandParameter="dashboard"/>
        <KeyBinding Modifiers="Ctrl" Key="D2" Command="{Binding NavCommand}" CommandParameter="incidents"/>
        <KeyBinding Modifiers="Ctrl" Key="D3" Command="{Binding NavCommand}" CommandParameter="rtr"/>
        <KeyBinding Modifiers="Ctrl" Key="D4" Command="{Binding NavCommand}" CommandParameter="forensics"/>
        <KeyBinding Modifiers="Ctrl" Key="D5" Command="{Binding NavCommand}" CommandParameter="memory"/>
        <KeyBinding Modifiers="Ctrl" Key="D6" Command="{Binding NavCommand}" CommandParameter="graph"/>
        <KeyBinding Modifiers="Ctrl" Key="D7" Command="{Binding NavCommand}" CommandParameter="health"/>
        <KeyBinding Modifiers="Ctrl" Key="D8" Command="{Binding NavCommand}" CommandParameter="settings"/>
        <KeyBinding Modifiers="Ctrl" Key="L" Command="{Binding SignOutCommand}"/>
        <KeyBinding Key="F1" Command="{Binding NavCommand}" CommandParameter="health"/>
        <KeyBinding Key="F5" Command="{Binding RefreshCommand}"/>
    </Window.InputBindings>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="26"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TopBar -->
        <Border Grid.ColumnSpan="2" Background="{DynamicResource Brush.Bg1}" BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Fill="{DynamicResource Brush.Accent}" Margin="0,0,8,0"/>
                    <TextBlock Text="CyberThrust" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Text}"/>
                    <TextBlock Text=".IRIS" FontSize="16" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                    <Border Style="{StaticResource ChipBase}" Background="#22FFD740" BorderBrush="#88FFD740" Margin="12,0,0,0">
                        <TextBlock Text="Internal Use / Non-Commercial Build" FontSize="11" Foreground="{DynamicResource Brush.Warn}"/>
                    </Border>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="UserBadge" Text="{Binding UserDisplay}" Style="{StaticResource Dim}" Margin="0,0,12,0"/>
                    <Button Content="Sair" Style="{StaticResource BtnGhost}" Command="{Binding SignOutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sidebar -->
        <Border Grid.Row="1" Background="{DynamicResource Brush.Bg1}" BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="0,0,1,0">
            <StackPanel Margin="8">
                <Button ToolTip="Ctrl+1" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="dashboard">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Dashboard"/><TextBlock Grid.Column="1" Text="Ctrl+1" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+2" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="incidents">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Incidentes"/><TextBlock Grid.Column="1" Text="Ctrl+2" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+3" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="rtr">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Console RTR"/><TextBlock Grid.Column="1" Text="Ctrl+3" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+4" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="forensics">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Forense (Disco)"/><TextBlock Grid.Column="1" Text="Ctrl+4" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+5" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="memory">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Memória"/><TextBlock Grid.Column="1" Text="Ctrl+5" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+6" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="graph">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Árvore de Ataque"/><TextBlock Grid.Column="1" Text="Ctrl+6" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Separator Margin="0,8" Background="{DynamicResource Brush.Stroke}"/>
                <Button ToolTip="Ctrl+7 ou F1" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="health">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Health Check"/><TextBlock Grid.Column="1" Text="F1" Style="{StaticResource Dim}"/></Grid>
                </Button>
                <Button ToolTip="Ctrl+8" Style="{StaticResource BtnGhost}" Margin="0,4" Command="{Binding NavCommand}" CommandParameter="settings">
                    <Grid HorizontalAlignment="Stretch"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                        <TextBlock Text="Configurações"/><TextBlock Grid.Column="1" Text="Ctrl+8" Style="{StaticResource Dim}"/></Grid>
                </Button>
            </StackPanel>
        </Border>

        <!-- Content host -->
        <ContentControl Grid.Row="1" Grid.Column="1" Content="{Binding CurrentView}"/>

        <!-- StatusBar -->
        <Border Grid.Row="2" Grid.ColumnSpan="2" Background="{DynamicResource Brush.Bg1}" BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Style="{StaticResource Dim}"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Entra:" Style="{StaticResource Dim}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding EntraStatus}" Style="{StaticResource Body}" Foreground="{Binding EntraStatusColor}" Margin="0,0,16,0"/>
                    <TextBlock Text="Falcon:" Style="{StaticResource Dim}" Margin="0,0,4,0"/>
                    <TextBlock Text="{Binding FalconStatus}" Style="{StaticResource Body}" Foreground="{Binding FalconStatusColor}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
