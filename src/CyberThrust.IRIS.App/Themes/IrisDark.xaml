<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Paleta CYBER THRUST IRIS — Dark Neon -->
    <Color x:Key="Color.Bg0">#FF05060A</Color>
    <Color x:Key="Color.Bg1">#FF0B0F18</Color>
    <Color x:Key="Color.Bg2">#FF111729</Color>
    <Color x:Key="Color.Bg3">#FF1A2238</Color>
    <Color x:Key="Color.Stroke">#FF253152</Color>
    <Color x:Key="Color.Text">#FFE6ECFF</Color>
    <Color x:Key="Color.TextDim">#FF8C9BC9</Color>
    <Color x:Key="Color.Accent">#FF00E5FF</Color>
    <Color x:Key="Color.Accent2">#FF7C4DFF</Color>
    <Color x:Key="Color.Success">#FF00E676</Color>
    <Color x:Key="Color.Warn">#FFFFD740</Color>
    <Color x:Key="Color.Danger">#FFFF5252</Color>
    <Color x:Key="Color.Critical">#FFFF0080</Color>

    <SolidColorBrush x:Key="Brush.Bg0"    Color="{StaticResource Color.Bg0}"/>
    <SolidColorBrush x:Key="Brush.Bg1"    Color="{StaticResource Color.Bg1}"/>
    <SolidColorBrush x:Key="Brush.Bg2"    Color="{StaticResource Color.Bg2}"/>
    <SolidColorBrush x:Key="Brush.Bg3"    Color="{StaticResource Color.Bg3}"/>
    <SolidColorBrush x:Key="Brush.Stroke" Color="{StaticResource Color.Stroke}"/>
    <SolidColorBrush x:Key="Brush.Text"   Color="{StaticResource Color.Text}"/>
    <SolidColorBrush x:Key="Brush.TextDim" Color="{StaticResource Color.TextDim}"/>
    <SolidColorBrush x:Key="Brush.Accent" Color="{StaticResource Color.Accent}"/>
    <SolidColorBrush x:Key="Brush.Accent2" Color="{StaticResource Color.Accent2}"/>
    <SolidColorBrush x:Key="Brush.Success" Color="{StaticResource Color.Success}"/>
    <SolidColorBrush x:Key="Brush.Warn"   Color="{StaticResource Color.Warn}"/>
    <SolidColorBrush x:Key="Brush.Danger" Color="{StaticResource Color.Danger}"/>
    <SolidColorBrush x:Key="Brush.Critical" Color="{StaticResource Color.Critical}"/>

    <LinearGradientBrush x:Key="Brush.Hero" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF050810" Offset="0"/>
        <GradientStop Color="#FF0B1228" Offset="0.5"/>
        <GradientStop Color="#FF050810" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="Brush.NeonGlow" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#FF00E5FF" Offset="0"/>
        <GradientStop Color="#FF7C4DFF" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
