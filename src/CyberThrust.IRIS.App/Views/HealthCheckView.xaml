<UserControl x:Class="CyberThrust.IRIS.App.Views.HealthCheckView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,16">
            <TextBlock Text="Health Check — Validação do Sistema" Style="{StaticResource H1}"/>
            <Button DockPanel.Dock="Right" Content="Executar novamente" Style="{StaticResource BtnGhost}" Command="{Binding RunCommand}"/>
        </DockPanel>

        <UniformGrid Grid.Row="1" Columns="4" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="Aprovados" Style="{StaticResource Dim}"/>
                    <TextBlock Text="{Binding PassCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Alertas" Style="{StaticResource Dim}"/>
                    <TextBlock Text="{Binding WarnCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Warn}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0">
                <StackPanel>
                    <TextBlock Text="Falhas" Style="{StaticResource Dim}"/>
                    <TextBlock Text="{Binding FailCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Danger}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                <StackPanel>
                    <TextBlock Text="Pulados" Style="{StaticResource Dim}"/>
                    <TextBlock Text="{Binding SkippedCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.TextDim}"/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <ProgressBar Grid.Row="2" Height="6" Value="{Binding CompletedPercent}" Maximum="100" Foreground="{DynamicResource Brush.Accent}" Background="{DynamicResource Brush.Bg2}" Margin="0,0,0,12"/>

        <Border Grid.Row="3" Style="{StaticResource Card}">
            <DataGrid ItemsSource="{Binding Results}" AutoGenerateColumns="False" HeadersVisibility="Column"
                      Background="Transparent" RowBackground="Transparent" AlternatingRowBackground="#08FFFFFF"
                      GridLinesVisibility="None" BorderThickness="0" Foreground="{DynamicResource Brush.Text}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Categoria" Binding="{Binding Category}" Width="140"/>
                    <DataGridTextColumn Header="Check" Binding="{Binding Name}" Width="240"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100"/>
                    <DataGridTextColumn Header="Detalhe" Binding="{Binding Message}" Width="*"/>
                    <DataGridTextColumn Header="Erro" Binding="{Binding Error.CodeString}" Width="140"/>
                    <DataGridTextColumn Header="Tempo" Binding="{Binding Duration, StringFormat=hh\\:mm\\:ss\\.ff}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</UserControl>
