<UserControl x:Class="CyberThrust.IRIS.App.Views.MemoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <Grid Margin="20">
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Memória" Style="{StaticResource H1}"/>
                <TextBlock Text="xmemdump nativo + Magnet DumpIt + WinPmem como fallback. Análise pós-coleta: SuperMem + MemProcFS." Style="{StaticResource Dim}" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
