<UserControl x:Class="CyberThrust.IRIS.App.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho com botões de ação globais -->
        <DockPanel Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Dashboard de Incidentes" Style="{StaticResource H1}"/>
                <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Dim}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Atualizar (F5)" Style="{StaticResource BtnGhost}" Command="{Binding RefreshCommand}" Margin="0,0,8,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Banner se não está conectado -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16" Background="#22FFD740" BorderBrush="#88FFD740"
                Visibility="{Binding ShowConfigBanner, Converter={StaticResource BoolVis}}">
            <DockPanel>
                <StackPanel>
                    <TextBlock Text="⚙️  Falcon ainda não está conectado" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Warn}" FontSize="14"/>
                    <TextBlock Text="Vá em Configurações (Ctrl+8) e preencha as credenciais da API key Falcon para começar a puxar alertas, hosts e detecções." Style="{StaticResource Dim}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                </StackPanel>
                <Button DockPanel.Dock="Right" Content="Abrir Configurações" Style="{StaticResource BtnPrimary}" Command="{Binding GoToSettingsCommand}" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- KPIs + Lista -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- KPI cards -->
            <UniformGrid Rows="1" Columns="5" Margin="0,0,0,16">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="DETECÇÕES" Style="{StaticResource Dim}"/>
                        <TextBlock Text="{Binding RecentDetections.Count}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                        <TextBlock Text="últimas 50" Style="{StaticResource Dim}" FontSize="10"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="CRÍTICAS" Style="{StaticResource Dim}"/>
                        <TextBlock Text="{Binding CriticalCount}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource Brush.Critical}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="ALTAS" Style="{StaticResource Dim}"/>
                        <TextBlock Text="{Binding HighCount}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource Brush.Danger}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="4,0">
                    <StackPanel>
                        <TextBlock Text="MÉDIAS" Style="{StaticResource Dim}"/>
                        <TextBlock Text="{Binding MediumCount}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource Brush.Warn}"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="HOSTS NA FROTA" Style="{StaticResource Dim}"/>
                        <TextBlock Text="{Binding FleetHostCount}" FontSize="36" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Lista de Incidentes estilo Cybereason MalOp -->
            <Border Grid.Row="1" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <DockPanel Margin="0,0,0,12">
                        <TextBlock Text="Detecções recentes" Style="{StaticResource H2}"/>
                        <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource Brush.Danger}" Margin="16,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                                   Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
                    </DockPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding RecentDetections}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Brush.Bg3}" BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- Coluna severidade -->
                                            <StackPanel VerticalAlignment="Center">
                                                <Border Background="{Binding SeverityColor}" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                                    <TextBlock Text="{Binding Severity}" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                                </Border>
                                                <TextBlock Text="{Binding TimestampUtc, StringFormat='HH:mm'}" Style="{StaticResource Dim}" FontSize="11" Margin="0,4,0,0"/>
                                            </StackPanel>
                                            <!-- Centro: host + descrição + MITRE -->
                                            <StackPanel Grid.Column="1" Margin="12,0">
                                                <TextBlock Text="{Binding Hostname}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="14"/>
                                                <TextBlock Text="{Binding Description}" Style="{StaticResource Body}" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                    <Border Background="{DynamicResource Brush.Bg2}" BorderBrush="{DynamicResource Brush.Accent}" BorderThickness="1" CornerRadius="10" Padding="6,2" Margin="0,0,6,0">
                                                        <TextBlock Text="{Binding Tactic}" FontSize="11" Foreground="{DynamicResource Brush.Accent}"/>
                                                    </Border>
                                                    <Border Background="{DynamicResource Brush.Bg2}" BorderBrush="{DynamicResource Brush.Accent2}" BorderThickness="1" CornerRadius="10" Padding="6,2">
                                                        <TextBlock Text="{Binding Technique}" FontSize="11" Foreground="{DynamicResource Brush.Accent2}"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                            <!-- Coluna direita: ações -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="Investigar" Style="{StaticResource BtnGhost}" Padding="10,4" FontSize="11" Margin="0,0,6,0"
                                                        Command="{Binding DataContext.InvestigateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <Button Content="Isolar host" Style="{StaticResource BtnGhost}" Padding="10,4" FontSize="11"
                                                        Command="{Binding DataContext.IsolateHostCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
