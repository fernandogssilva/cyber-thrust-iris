<Window x:Class="CyberThrust.IRIS.App.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="520" Height="320"
        WindowStyle="None" ResizeMode="NoResize" AllowsTransparency="True"
        Background="Transparent" WindowStartupLocation="CenterScreen" ShowInTaskbar="False"
        Topmost="True">
    <Border CornerRadius="14" BorderThickness="1">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#FF050810" Offset="0"/>
                <GradientStop Color="#FF0B1228" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Border.BorderBrush>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#FF00E5FF" Offset="0"/>
                <GradientStop Color="#FF7C4DFF" Offset="1"/>
            </LinearGradientBrush>
        </Border.BorderBrush>
        <Grid Margin="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel VerticalAlignment="Center">
                <Ellipse Width="18" Height="18" Fill="#FF00E5FF" HorizontalAlignment="Left"/>
                <TextBlock Text="CyberThrust" FontSize="42" FontWeight="Bold" Foreground="#FFE6ECFF" Margin="0,12,0,0"/>
                <TextBlock Text=".IRIS" FontSize="42" FontWeight="Bold" Foreground="#FF00E5FF" Margin="0,-8,0,0"/>
                <TextBlock Text="Incident Response &amp; Investigation Suite" Foreground="#FF8C9BC9" FontSize="13" Margin="0,8,0,0"/>
                <Border Background="#22FFD740" BorderBrush="#88FFD740" BorderThickness="1" CornerRadius="10" Padding="8,2" HorizontalAlignment="Left" Margin="0,12,0,0">
                    <TextBlock Text="Open Source · Apache 2.0 · v0.2.1" Foreground="#FFFFD740" FontSize="11"/>
                </Border>
            </StackPanel>
            <StackPanel Grid.Row="1">
                <ProgressBar x:Name="Bar" IsIndeterminate="True" Height="4" Background="#FF111729" Foreground="#FF00E5FF" BorderThickness="0"/>
                <TextBlock x:Name="Status" Text="Iniciando…" Foreground="#FF8C9BC9" FontSize="11" Margin="0,6,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
