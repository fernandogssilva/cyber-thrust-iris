<UserControl x:Class="CyberThrust.IRIS.App.Views.ForensicsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="TermLine" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"     Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,1,0,0"/>
        </Style>

        <Style x:Key="ToolCard" TargetType="Border">
            <Setter Property="Background"      Value="{DynamicResource Brush.Bg3}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource Brush.Stroke}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="7"/>
            <Setter Property="Padding"         Value="10,8"/>
            <Setter Property="Margin"          Value="0,0,0,6"/>
        </Style>

        <Style x:Key="ScopeChk" TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="Margin"     Value="0,4,0,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Row 0 — Header card
        ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: title + status -->
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <DockPanel>
                        <TextBlock Text="🔬  Forense de Disco (Live)" Style="{StaticResource H1}"
                                   FontSize="20" VerticalAlignment="Center"/>
                        <Border Width="9" Height="9" CornerRadius="4.5" Margin="8,0,0,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding HostnameDisplay}"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text="  ·  " Foreground="{DynamicResource Brush.TextDim}" FontSize="12"
                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}"/>
                        <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Dim}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Right: AID input + buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AID:" Foreground="{DynamicResource Brush.TextDim}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding AidInput, UpdateSourceTrigger=PropertyChanged}"
                             Width="200" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="← Detecções" Command="{Binding BackToAlertsCommand}"
                            Style="{StaticResource BtnGhost}" Margin="12,0,0,0" Padding="9,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Row 1 — Config panel | Splitter | Terminal
        ═════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" MinWidth="220" MaxWidth="440"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: configuration panel ────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Section: Tool selection -->
                        <TextBlock Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,0,0,8">
                            🛠  FERRAMENTA DE COLETA
                        </TextBlock>

                        <!-- KAPE card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ToolCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsKape}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                            <Setter Property="Background"  Value="#18003040"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton IsChecked="{Binding IsKape}" GroupName="FTool" Cursor="Hand">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="KROLL"
                                                   Foreground="{DynamicResource Brush.Accent}"
                                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="📦  KAPE"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                    </DockPanel>
                                    <TextBlock Text="Kroll Artifact Parser — triage rápida com alvos configuráveis por escopo."
                                               Foreground="{DynamicResource Brush.TextDim}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>

                        <!-- Velociraptor card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ToolCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsVelociraptor}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                            <Setter Property="Background"  Value="#18003040"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton IsChecked="{Binding IsVelociraptor}" GroupName="FTool" Cursor="Hand">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="OSS"
                                                   Foreground="{DynamicResource Brush.Accent2}"
                                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="🦖  Velociraptor"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                    </DockPanel>
                                    <TextBlock Text="Velocidex DFIR platform — VQL hunts de alta performance, KapeFiles.Targets."
                                               Foreground="{DynamicResource Brush.TextDim}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>

                        <!-- UAC card -->
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ToolCard}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUac}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}"/>
                                            <Setter Property="Background"  Value="#18003040"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <RadioButton IsChecked="{Binding IsUac}" GroupName="FTool" Cursor="Hand">
                                <RadioButton.Template>
                                    <ControlTemplate TargetType="RadioButton">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </RadioButton.Template>
                                <StackPanel>
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Right" Text="IR NINJA"
                                                   Foreground="{DynamicResource Brush.Warn}"
                                                   FontSize="9" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="🥷  UAC"
                                                   Foreground="{DynamicResource Brush.Text}"
                                                   FontWeight="SemiBold" FontSize="13"/>
                                    </DockPanel>
                                    <TextBlock Text="Unix Artifact Collector — coleta portátil Windows/Linux/macOS."
                                               Foreground="{DynamicResource Brush.TextDim}"
                                               FontSize="10" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </RadioButton>
                        </Border>

                        <!-- Prerequisites note (non-native) -->
                        <Border Background="#10FFD740" BorderBrush="{DynamicResource Brush.Warn}"
                                BorderThickness="1" CornerRadius="6" Padding="8,6" Margin="0,2,0,6">
                            <StackPanel>
                                <TextBlock Text="⚠  Pré-requisito" Foreground="{DynamicResource Brush.Warn}"
                                           FontWeight="SemiBold" FontSize="10"/>
                                <TextBlock TextWrapping="Wrap" FontSize="10" Margin="0,3,0,0"
                                           Foreground="{DynamicResource Brush.TextDim}">
                                    Faça o <Run Foreground="{DynamicResource Brush.Accent}" FontFamily="Consolas">put</Run>
                                    do binário da ferramenta em <Run Foreground="{DynamicResource Brush.Accent}" FontFamily="Consolas">C:\Windows\Temp\</Run>
                                    via Console RTR antes de iniciar.
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Separator Margin="0,4,0,8" Background="{DynamicResource Brush.Stroke}"/>

                        <!-- Section: Scope -->
                        <DockPanel Margin="0,0,0,6">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                <Button Content="Todos" Command="{Binding SelectAllCommand}"
                                        Style="{StaticResource BtnGhost}" Padding="7,3" FontSize="10"/>
                                <Button Content="Nenhum" Command="{Binding SelectNoneCommand}"
                                        Style="{StaticResource BtnGhost}" Padding="7,3" FontSize="10" Margin="4,0,0,0"/>
                            </StackPanel>
                            <TextBlock Foreground="{DynamicResource Brush.Accent}"
                                       FontWeight="SemiBold" FontSize="10" VerticalAlignment="Center">
                                🗂  ESCOPO DE COLETA
                            </TextBlock>
                        </DockPanel>

                        <!-- Scope checkboxes -->
                        <CheckBox Content="📋  Logs de Eventos (EventLogs)"
                                  IsChecked="{Binding CollectEvents}" Style="{StaticResource ScopeChk}"/>
                        <CheckBox Content="🗝  Registro (Registry Hives)"
                                  IsChecked="{Binding CollectRegistry}" Style="{StaticResource ScopeChk}"/>
                        <CheckBox Content="⚡  Prefetch (execuções)"
                                  IsChecked="{Binding CollectPrefetch}" Style="{StaticResource ScopeChk}"/>
                        <CheckBox Content="🌐  Navegadores (Browsers)"
                                  IsChecked="{Binding CollectBrowser}" Style="{StaticResource ScopeChk}"/>
                        <CheckBox Content="💻  Sistema (LNK, Recycle, FS)"
                                  IsChecked="{Binding CollectSystem}" Style="{StaticResource ScopeChk}"/>
                        <CheckBox Content="📡  Rede (Network Cards)"
                                  IsChecked="{Binding CollectNetwork}" Style="{StaticResource ScopeChk}"/>

                        <Separator Margin="0,8,0,4" Background="{DynamicResource Brush.Stroke}"/>

                        <!-- Full triage toggle -->
                        <Border Background="#10FF5252" BorderBrush="{DynamicResource Brush.Danger}"
                                BorderThickness="1" CornerRadius="6" Padding="10,7" Margin="0,0,0,8">
                            <CheckBox Content="🎯  Triage Completo  (!FullTriage)"
                                      IsChecked="{Binding CollectFull}"
                                      Foreground="{DynamicResource Brush.Danger}"
                                      FontWeight="SemiBold" FontSize="12"/>
                        </Border>

                        <!-- Start collection button -->
                        <Button Content="▶  Iniciar Coleta Forense"
                                Command="{Binding StartCollectionCommand}"
                                IsEnabled="{Binding CanRun}"
                                Style="{StaticResource BtnPrimary}"
                                Padding="0,12" FontSize="13"/>

                        <!-- Busy indicator -->
                        <TextBlock Text="⟳  Aguardando Falcon API…"
                                   Foreground="{DynamicResource Brush.Accent}" FontSize="11"
                                   HorizontalAlignment="Center" Margin="0,8,0,0"
                                   Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"/>

                        <!-- Clear terminal -->
                        <Button Content="🗑  Limpar Terminal"
                                Command="{Binding ClearTerminalCommand}"
                                Style="{StaticResource BtnGhost}"
                                Margin="0,6,0,0" Padding="0,7" FontSize="11"/>

                        <!-- ── Post-collect section ────────────────────── -->
                        <StackPanel Visibility="{Binding CollectComplete, Converter={StaticResource BoolVis}}"
                                    Margin="0,14,0,0">
                            <Separator Margin="0,0,0,10" Background="{DynamicResource Brush.Success}"/>
                            <TextBlock Foreground="{DynamicResource Brush.Success}"
                                       FontWeight="SemiBold" FontSize="10" Margin="0,0,0,6">
                                ✅  COLETA INICIADA COM SUCESSO
                            </TextBlock>
                            <TextBlock Text="Artefatos no endpoint:" Style="{StaticResource Dim}" FontSize="10"/>
                            <TextBox Text="{Binding OutputPath, Mode=OneWay}"
                                     IsReadOnly="True" FontFamily="Consolas" FontSize="9.5"
                                     Background="{DynamicResource Brush.Bg3}"
                                     TextWrapping="Wrap" Margin="0,3,0,8"/>
                            <TextBlock TextWrapping="Wrap" FontSize="10"
                                       Foreground="{DynamicResource Brush.TextDim}" Margin="0,0,0,6">
                                Para recuperar, abra o Console RTR e execute:
                                <LineBreak/>
                                <Run FontFamily="Consolas" Foreground="{DynamicResource Brush.Accent}">get </Run><Run Text="{Binding OutputPath, Mode=OneWay}" FontFamily="Consolas" Foreground="{DynamicResource Brush.Accent}"/><Run FontFamily="Consolas" Foreground="{DynamicResource Brush.Accent}">.zip</Run>
                            </TextBlock>
                        </StackPanel>

                        <!-- Zero-storage note -->
                        <Border Margin="0,16,0,0" Background="#0C00E5FF"
                                BorderBrush="{DynamicResource Brush.Accent}"
                                BorderThickness="1" CornerRadius="6" Padding="8,6">
                            <TextBlock FontSize="9.5" TextWrapping="Wrap"
                                       Foreground="{DynamicResource Brush.TextDim}">
                                <Run Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold">Zero-Storage:</Run>
                                Artefatos coletados no endpoint remoto via RTR. Nenhum dado é gravado localmente nesta máquina.
                            </TextBlock>
                        </Border>

                        <Border Height="16"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Stroke}" Cursor="SizeWE"/>

            <!-- ── Right: Terminal output ─────────────────────────────── -->
            <Border Grid.Column="2" Background="#080B15" CornerRadius="8"
                    BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1">
                <ScrollViewer x:Name="TerminalScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Terminal}"
                                  Padding="14,10" Background="Transparent" Focusable="False">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           Foreground="{Binding Fore}"
                                           Style="{StaticResource TermLine}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>
