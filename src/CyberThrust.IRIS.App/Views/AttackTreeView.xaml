<UserControl x:Class="CyberThrust.IRIS.App.Views.AttackTreeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="{DynamicResource Brush.Bg0}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,12">
            <TextBlock Text="Árvore de Ataque" Style="{StaticResource H1}"/>
            <Button DockPanel.Dock="Right" Content="Recarregar" Style="{StaticResource BtnGhost}" Command="{Binding ReloadCommand}"/>
        </DockPanel>
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="0">
            <wv:WebView2 x:Name="Browser" />
        </Border>
    </Grid>
</UserControl>
