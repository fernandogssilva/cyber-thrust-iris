<UserControl x:Class="CyberThrust.IRIS.App.Views.AlertsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Detecções" Style="{StaticResource H1}"/>
                <TextBlock Text="{Binding ResultsLabel}" Foreground="{DynamicResource Brush.Accent}" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0"/>
                <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Dim}" Margin="0,2,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Limpar filtros" Style="{StaticResource BtnGhost}" Command="{Binding ClearFiltersCommand}" Margin="0,0,8,0"/>
                <Button Content="Atualizar (F5)" Style="{StaticResource BtnPrimary}" Command="{Binding LoadCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- Banner config -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Background="#22FFD740" BorderBrush="#88FFD740"
                Visibility="{Binding ShowConfigBanner, Converter={StaticResource BoolVis}}">
            <DockPanel>
                <TextBlock Text="Configure as credenciais Falcon em Configurações (Ctrl+8) para puxar detecções." Style="{StaticResource Dim}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Abrir Configurações" Style="{StaticResource BtnPrimary}" Command="{Binding GoToSettingsCommand}"/>
            </DockPanel>
        </Border>

        <!-- Filter row (chips estilo NG-SIEM) -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Padding="10,8" FontFamily="Segoe UI"/>
                    <TextBlock Text="🔍  Buscar detecções (hostname, usuário, técnica, nome…)" Foreground="{DynamicResource Brush.TextDim}" IsHitTestVisible="False" VerticalAlignment="Center" Margin="12,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchText}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <ComboBox Grid.Column="1" ItemsSource="{Binding SeverityOptions}" SelectedItem="{Binding SelectedSeverity}" Margin="4,0"/>
                <ComboBox Grid.Column="2" ItemsSource="{Binding TimeOptions}" SelectedItem="{Binding SelectedTime}" Margin="4,0"/>
                <ComboBox Grid.Column="3" ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="4,0"/>
                <ComboBox Grid.Column="4" ItemsSource="{Binding ProductOptions}" SelectedItem="{Binding SelectedProduct}" Margin="4,0,0,0"/>
            </Grid>
        </Border>

        <!-- DataGrid estilo NG-SIEM -->
        <Border Grid.Row="3" Style="{StaticResource Card}" Padding="0">
            <Grid>
                <DataGrid ItemsSource="{Binding AlertsView}" AutoGenerateColumns="False"
                          CanUserAddRows="False" CanUserDeleteRows="False"
                          IsReadOnly="True" GridLinesVisibility="None"
                          HeadersVisibility="Column" SelectionMode="Extended"
                          Background="Transparent" RowBackground="Transparent"
                          AlternatingRowBackground="#06FFFFFF"
                          BorderThickness="0" FontSize="12">
                    <DataGrid.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource Brush.Bg3}" Padding="8,4" Margin="0,8,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource Brush.Accent}" FontWeight="SemiBold" FontSize="12"/>
                                            <TextBlock Text=" · " Foreground="{DynamicResource Brush.TextDim}" Margin="6,0"/>
                                            <TextBlock Text="{Binding ItemCount, StringFormat='{}{0} detecções'}" Foreground="{DynamicResource Brush.TextDim}" FontSize="11"/>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </DataGrid.GroupStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="" Width="40">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Severity" Width="100">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Background="{Binding SeverityBrush}" CornerRadius="3" Padding="6,1" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding SeverityLabel}" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Detect time" Binding="{Binding DetectTime}" Width="90">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="FontFamily" Value="Consolas"/><Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Detection name" Binding="{Binding DetectionName}" Width="*">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="100">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.Accent2}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Account name" Binding="{Binding AccountName}" Width="170">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Source endpoint" Binding="{Binding SourceEndpoint}" Width="170">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="{DynamicResource Brush.Text}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Tactic · Technique" Binding="{Binding TacticTechnique}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="TextTrimming" Value="CharacterEllipsis"/><Setter Property="Foreground" Value="{DynamicResource Brush.Accent}"/><Setter Property="FontSize" Value="11"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Assigned to" Binding="{Binding AssignedTo}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                        <DataGridTextColumn Header="Status" Binding="{Binding StatusLabel}" Width="120">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Brush.Warn}"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="FontSize" Value="10"/></Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource Brush.Danger}" TextWrapping="Wrap" Margin="12"
                           Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
