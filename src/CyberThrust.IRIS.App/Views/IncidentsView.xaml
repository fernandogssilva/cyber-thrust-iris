<UserControl x:Class="CyberThrust.IRIS.App.Views.IncidentsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Incidentes" Style="{StaticResource H1}"/>
                <TextBlock Text="Agrupamentos de detecções relacionadas · Falcon Incidents API v1 · fine_score 0-100" Style="{StaticResource Dim}" Margin="0,4,0,0"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="Ver detecções →" Style="{StaticResource BtnGhost}" Command="{Binding GoToAlertsCommand}" Margin="0,0,8,0"/>
                <Button Content="Atualizar" Style="{StaticResource BtnPrimary}" Command="{Binding LoadCommand}"/>
            </StackPanel>
        </DockPanel>

        <!-- Banner config -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,12" Background="#22FFD740" BorderBrush="#88FFD740"
                Visibility="{Binding ShowConfigBanner, Converter={StaticResource BoolVis}}">
            <DockPanel>
                <TextBlock Text="Configure as credenciais Falcon em Configurações (Ctrl+8)." Style="{StaticResource Dim}" VerticalAlignment="Center"/>
                <Button DockPanel.Dock="Right" Content="Abrir Configurações" Style="{StaticResource BtnPrimary}" Command="{Binding GoToSettingsCommand}"/>
            </DockPanel>
        </Border>

        <!-- Filtros -->
        <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,12" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Margin="0,0,8,0">
                    <TextBlock Text="PERÍODO" Style="{StaticResource Dim}" FontSize="10"/>
                    <ComboBox ItemsSource="{Binding TimeOptions}" SelectedItem="{Binding SelectedTime}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="STATUS" Style="{StaticResource Dim}" FontSize="10"/>
                    <ComboBox ItemsSource="{Binding StatusOptions}" SelectedItem="{Binding SelectedStatus}" Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- KPIs -->
        <UniformGrid Grid.Row="3" Rows="1" Columns="5" Margin="0,0,0,12">
            <Border Style="{StaticResource Card}" Margin="0,0,4,0" Padding="12">
                <StackPanel><TextBlock Text="TOTAL" Style="{StaticResource Dim}" FontSize="10"/><TextBlock Text="{Binding TotalCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="2,0" Padding="12">
                <StackPanel><TextBlock Text="CRÍTICOS+ALTOS" Style="{StaticResource Dim}" FontSize="10"/><TextBlock Text="{Binding CriticalCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Critical}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="2,0" Padding="12">
                <StackPanel><TextBlock Text="NOVOS" Style="{StaticResource Dim}" FontSize="10"/><TextBlock Text="{Binding NewCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Warn}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="2,0" Padding="12">
                <StackPanel><TextBlock Text="EM PROGRESSO" Style="{StaticResource Dim}" FontSize="10"/><TextBlock Text="{Binding InProgressCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent2}"/></StackPanel>
            </Border>
            <Border Style="{StaticResource Card}" Margin="4,0,0,0" Padding="12">
                <StackPanel><TextBlock Text="FECHADOS" Style="{StaticResource Dim}" FontSize="10"/><TextBlock Text="{Binding ClosedCount}" FontSize="32" FontWeight="Bold" Foreground="{DynamicResource Brush.Success}"/></StackPanel>
            </Border>
        </UniformGrid>

        <!-- Lista de Incidentes -->
        <Border Grid.Row="4" Style="{StaticResource Card}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <DockPanel Margin="0,0,0,12">
                    <TextBlock Text="Incidentes ativos" Style="{StaticResource H2}"/>
                    <TextBlock DockPanel.Dock="Right" Text="{Binding StatusLine}" Style="{StaticResource Dim}" VerticalAlignment="Center"/>
                </DockPanel>
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Incidents}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource Brush.Bg3}" BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1" CornerRadius="8" Padding="14" Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Background="{Binding SeverityBrush}" CornerRadius="4" Padding="8,2" HorizontalAlignment="Left" VerticalAlignment="Top">
                                            <TextBlock Text="{Binding SeverityLabel}" Foreground="Black" FontWeight="Bold" FontSize="10"/>
                                        </Border>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding FineScoreLabel}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource Brush.Accent}"/>
                                            <TextBlock Text="fine_score" Style="{StaticResource Dim}" FontSize="10"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" Margin="12,0">
                                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource Brush.Text}" FontSize="14"/>
                                            <TextBlock Text="{Binding HostsCsv}" Foreground="{DynamicResource Brush.Accent2}" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding HostsLabel}" Style="{StaticResource Dim}" FontSize="11" Margin="0,2,0,0"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                                <TextBlock Text="{Binding TacticsCsv}" Foreground="{DynamicResource Brush.Accent}" FontSize="11"/>
                                                <TextBlock Text="  ·  " Foreground="{DynamicResource Brush.TextDim}" FontSize="11"/>
                                                <TextBlock Text="{Binding TechniquesCsv}" Foreground="{DynamicResource Brush.Accent2}" FontSize="11"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding AssignedTo}" Style="{StaticResource Dim}" FontSize="10"/>
                                            <TextBlock Text="{Binding StatusLabel}" Foreground="{DynamicResource Brush.Warn}" FontSize="11" FontWeight="Bold" Margin="0,2,0,0"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="4" Text="{Binding AgeLabel}" Foreground="{DynamicResource Brush.TextDim}" FontSize="11" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
                <TextBlock Text="{Binding LastError}" Foreground="{DynamicResource Brush.Danger}" Grid.Row="1" Margin="0,8,0,0" TextWrapping="Wrap"
                           Visibility="{Binding HasError, Converter={StaticResource BoolVis}}"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>
