             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <Grid Margin="20">
        <Border Style="{StaticResource Card}">
            <StackPanel>
                <TextBlock Text="Incidentes" Style="{StaticResource H1}"/>
                <TextBlock Text="Tela em construção — usa Falcon Alerts v2 + agrupamento por tactic/technique. Próxima iteração." Style="{StaticResource Dim}" Margin="0,12,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
