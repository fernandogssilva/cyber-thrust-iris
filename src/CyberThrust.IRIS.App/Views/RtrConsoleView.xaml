<UserControl x:Class="CyberThrust.IRIS.App.Views.RtrConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <!-- Terminal line item template helper styles -->
        <Style x:Key="TermLine" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"   Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"     Value="0,1,0,0"/>
        </Style>

        <!-- Quick-command pill button -->
        <Style x:Key="QuickBtn" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Padding"    Value="10,4"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Margin"     Value="0,0,5,5"/>
        </Style>

        <!-- Action button (contain / lift) -->
        <Style x:Key="ActionBtn" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin"  Value="0,0,6,0"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header / connection bar -->
            <RowDefinition Height="Auto"/>  <!-- Actions toolbar -->
            <RowDefinition Height="*"/>     <!-- Terminal output -->
            <RowDefinition Height="Auto"/>  <!-- Command input bar -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 0 — Header: title + AID input + connect controls
        ════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>  <!-- Title block -->
                    <ColumnDefinition Width="*"/>     <!-- spacer -->
                    <ColumnDefinition Width="Auto"/>  <!-- connection controls -->
                </Grid.ColumnDefinitions>

                <!-- Title + status indicator -->
                <StackPanel Grid.Column="0">
                    <DockPanel>
                        <TextBlock Text="Console RTR" Style="{StaticResource H1}"/>
                        <!-- Connection dot -->
                        <Border DockPanel.Dock="Left" Width="10" Height="10" CornerRadius="5"
                                Margin="10,0,0,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="{Binding HostnameDisplay}" Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text=" · " Foreground="{DynamicResource Brush.TextDim}" FontSize="12"
                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}"/>
                        <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Dim}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- AID input + connect/disconnect buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AID:" Foreground="{DynamicResource Brush.TextDim}"
                               FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="AidBox"
                             Text="{Binding AidInput, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsNotConnected}"
                             Width="260" FontFamily="Consolas" FontSize="12"
                             VerticalAlignment="Center"
                             ToolTip="AID do agente Falcon instalado no endpoint-alvo"/>
                    <Button Content="Conectar"
                            Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding CanConnect}"
                            Style="{StaticResource BtnPrimary}"
                            Margin="8,0,0,0" Padding="14,6"/>
                    <Button Content="Desconectar"
                            Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource BtnGhost}"
                            Margin="6,0,0,0" Padding="14,6"/>
                    <Button Content="← Detecções"
                            Command="{Binding BackToAlertsCommand}"
                            Style="{StaticResource BtnGhost}"
                            Margin="12,0,0,0" Padding="12,6"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 1 — Actions toolbar: host isolation + quick commands
        ════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,10">
            <StackPanel>

                <!-- Host isolation row -->
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="Contenção:" Foreground="{DynamicResource Brush.TextDim}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"
                               Width="80"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="🔒  Conter Host"
                                Command="{Binding ContainHostCommand}"
                                Style="{StaticResource ActionBtn}"
                                IsEnabled="{Binding CanConnect}"
                                ToolTip="Isola o endpoint via Falcon Network Containment — bloqueia todo tráfego externo"/>
                        <Button Content="🔓  Levantar Contenção"
                                Command="{Binding LiftContainmentCommand}"
                                Style="{StaticResource ActionBtn}"
                                IsEnabled="{Binding CanConnect}"
                                ToolTip="Remove o isolamento e reintegra o host à rede"/>

                        <!-- Busy spinner -->
                        <Border Width="20" Height="20" VerticalAlignment="Center" Margin="8,0,0,0"
                                Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}">
                            <TextBlock Text="⟳" Foreground="{DynamicResource Brush.Accent}"
                                       FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </DockPanel>

                <!-- Quick commands row -->
                <DockPanel>
                    <TextBlock Text="Rápido:" Foreground="{DynamicResource Brush.TextDim}"
                               FontSize="11" FontWeight="SemiBold" VerticalAlignment="Top"
                               Margin="0,4,0,0" Width="80"/>
                    <WrapPanel>
                        <Button Content="ls"          Command="{Binding QuickCommandCommand}" CommandParameter="ls"              Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="ps"          Command="{Binding QuickCommandCommand}" CommandParameter="ps"              Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="netstat"     Command="{Binding QuickCommandCommand}" CommandParameter="netstat -an"     Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="ipconfig"    Command="{Binding QuickCommandCommand}" CommandParameter="ipconfig /all"   Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="whoami"      Command="{Binding QuickCommandCommand}" CommandParameter="whoami"          Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="env"         Command="{Binding QuickCommandCommand}" CommandParameter="env"             Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="history"     Command="{Binding QuickCommandCommand}" CommandParameter="history"         Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="reg query"   Command="{Binding QuickCommandCommand}" CommandParameter="reg query HKLM\SOFTWARE\Microsoft\Windows\CurrentVersion /v ProgramFilesDir" Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="tasklist"    Command="{Binding QuickCommandCommand}" CommandParameter="runscript -Raw=Get-Process | Sort-Object CPU -Descending | Select -First 20 | Format-Table Name,Id,CPU,WorkingSet64 -AutoSize" Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="autoruns"    Command="{Binding QuickCommandCommand}" CommandParameter="runscript -Raw=Get-ItemProperty HKLM:\Software\Microsoft\Windows\CurrentVersion\Run" Style="{StaticResource QuickBtn}" IsEnabled="{Binding IsConnected}"/>
                        <Button Content="🗑 Limpar"   Command="{Binding ClearTerminalCommand}" Style="{StaticResource QuickBtn}"/>
                    </WrapPanel>
                </DockPanel>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 2 — Terminal output (dark, monospace, scrollable)
        ════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Background="#080B15" CornerRadius="8"
                BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1">
            <ScrollViewer x:Name="TerminalScroll"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Padding="0,0,4,0">
                <ItemsControl x:Name="TerminalOutput"
                              ItemsSource="{Binding Terminal}"
                              Padding="14,10"
                              Background="Transparent"
                              Focusable="False">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Fore}"
                                       Style="{StaticResource TermLine}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- ═══════════════════════════════════════════════════════════════════
             Row 3 — Command input bar
        ════════════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="3" Background="#080B15" CornerRadius="8"
                BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1"
                Margin="0,4,0,0" Padding="10,6">
            <DockPanel>
                <!-- Prompt glyph -->
                <TextBlock DockPanel.Dock="Left"
                           Text="PS ❯"
                           FontFamily="Consolas, Courier New, monospace"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="#40E0FF"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0"/>

                <!-- Execute button -->
                <Button DockPanel.Dock="Right"
                        Content="↵  Executar"
                        Command="{Binding SendCommand}"
                        IsEnabled="{Binding IsConnected}"
                        Style="{StaticResource BtnPrimary}"
                        Margin="8,0,0,0" Padding="16,6"/>

                <!-- Command TextBox (Enter key handled in code-behind) -->
                <TextBox x:Name="CmdInput"
                         Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding IsConnected}"
                         Background="Transparent"
                         Foreground="#E2E8FF"
                         CaretBrush="#40E0FF"
                         BorderThickness="0"
                         FontFamily="Consolas, Courier New, monospace"
                         FontSize="13"
                         VerticalAlignment="Center"
                         ToolTip="Digite um comando RTR e pressione Enter ou clique Executar"/>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>
