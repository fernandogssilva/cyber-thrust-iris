<UserControl x:Class="CyberThrust.IRIS.App.Views.RtrConsoleView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource Brush.Bg0}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>

        <Style x:Key="TermLine" TargetType="TextBlock">
            <Setter Property="FontFamily"   Value="Consolas, Courier New, monospace"/>
            <Setter Property="FontSize"     Value="12.5"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
            <Setter Property="Margin"       Value="0,1,0,0"/>
        </Style>

        <Style x:Key="SideHead" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,10,0,4"/>
        </Style>

        <Style x:Key="FiltLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource Brush.TextDim}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="Margin"     Value="0,5,0,1"/>
        </Style>

        <Style x:Key="FiltBox" TargetType="TextBox">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Padding"    Value="5,3"/>
        </Style>

        <!-- Base script button (all inherit from BtnGhost) -->
        <Style x:Key="SBtn" TargetType="Button" BasedOn="{StaticResource BtnGhost}">
            <Setter Property="Margin"                    Value="0,0,0,3"/>
            <Setter Property="Padding"                   Value="6,3"/>
            <Setter Property="FontSize"                  Value="11"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SBtnMed"  TargetType="Button" BasedOn="{StaticResource SBtn}">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Warn}"/>
        </Style>

        <Style x:Key="SBtnHigh" TargetType="Button" BasedOn="{StaticResource SBtn}">
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Danger}"/>
            <Setter Property="Foreground"  Value="{DynamicResource Brush.Danger}"/>
        </Style>

        <!-- Shared DataTemplate for script buttons (Low risk) -->
        <DataTemplate x:Key="ScriptItemLow">
            <Button Command="{Binding DataContext.RunScriptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    IsEnabled="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="{Binding Description}"
                    Style="{StaticResource SBtn}">
                <TextBlock FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}  {1}">
                            <Binding Path="Icon"/>
                            <Binding Path="Name"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="ScriptItemMed">
            <Button Command="{Binding DataContext.RunScriptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    IsEnabled="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="{Binding Description}"
                    Style="{StaticResource SBtnMed}">
                <TextBlock FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}  {1}">
                            <Binding Path="Icon"/>
                            <Binding Path="Name"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="ScriptItemHigh">
            <Button Command="{Binding DataContext.RunScriptCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    CommandParameter="{Binding}"
                    IsEnabled="{Binding DataContext.IsConnected, RelativeSource={RelativeSource AncestorType=UserControl}}"
                    ToolTip="{Binding Description}"
                    Style="{StaticResource SBtnHigh}">
                <TextBlock FontSize="11">
                    <TextBlock.Text>
                        <MultiBinding StringFormat="{}{0}  {1}">
                            <Binding Path="Icon"/>
                            <Binding Path="Name"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Button>
        </DataTemplate>
    </UserControl.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════════════════════
             Row 0 — Connection header
        ═════════════════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="14,10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <DockPanel>
                        <TextBlock Text="Console RTR" Style="{StaticResource H1}" VerticalAlignment="Center"/>
                        <Border Width="9" Height="9" CornerRadius="4.5" Margin="8,0,0,0" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource Brush.Danger}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource Brush.Success}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding HostnameDisplay}"
                                   Foreground="{DynamicResource Brush.Accent}"
                                   FontSize="12" FontWeight="SemiBold"/>
                        <TextBlock Text=" · " Foreground="{DynamicResource Brush.TextDim}" FontSize="12"
                                   Visibility="{Binding IsConnected, Converter={StaticResource BoolVis}}"/>
                        <TextBlock Text="{Binding StatusLine}" Style="{StaticResource Dim}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="AID:" Foreground="{DynamicResource Brush.TextDim}"
                               FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding AidInput, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding IsNotConnected}"
                             Width="220" FontFamily="Consolas" FontSize="11" VerticalAlignment="Center"/>
                    <Button Content="Conectar"     Command="{Binding ConnectCommand}"
                            IsEnabled="{Binding CanConnect}"
                            Style="{StaticResource BtnPrimary}" Margin="7,0,0,0" Padding="12,5"/>
                    <Button Content="Desconectar"  Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}"
                            Style="{StaticResource BtnGhost}"  Margin="5,0,0,0" Padding="12,5"/>
                    <Button Content="🔒 Conter"    Command="{Binding ContainHostCommand}"
                            IsEnabled="{Binding CanConnect}"
                            Style="{StaticResource BtnGhost}"  Margin="10,0,0,0" Padding="9,5"/>
                    <Button Content="🔓 Levantar"  Command="{Binding LiftContainmentCommand}"
                            IsEnabled="{Binding CanConnect}"
                            Style="{StaticResource BtnGhost}"  Margin="4,0,0,0" Padding="9,5"/>
                    <Button Content="← Detecções"  Command="{Binding BackToAlertsCommand}"
                            Style="{StaticResource BtnGhost}"  Margin="12,0,0,0" Padding="9,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════════════════════
             Row 1 — Sidebar | Splitter | Terminal
        ═════════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="255" MinWidth="180" MaxWidth="400"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left sidebar ──────────────────────────────────────── -->
            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="12,10">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>

                        <!-- Investigation Filters -->
                        <TextBlock Style="{StaticResource SideHead}"
                                   Foreground="{DynamicResource Brush.Accent}">
                            🔍  FILTROS DE INVESTIGAÇÃO
                        </TextBlock>

                        <!-- Host -->
                        <TextBlock Text="Hostname" Style="{StaticResource FiltLabel}"/>
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="🔎"
                                    Command="{Binding SearchHostCommand}"
                                    Style="{StaticResource BtnGhost}"
                                    Padding="6,3" Margin="4,0,0,0"
                                    ToolTip="Localizar AID pelo hostname"/>
                            <TextBox x:Name="HostFilterBox"
                                     Text="{Binding HostFilter, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FiltBox}"
                                     ToolTip="Hostname para busca. Use 🔎 para obter o AID automaticamente."/>
                        </DockPanel>
                        <TextBlock Text="{Binding HostSearchResult}" FontSize="10" TextWrapping="Wrap"
                                   Foreground="{DynamicResource Brush.Success}" Margin="0,2,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HostSearchResult}" Value="">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <!-- IP -->
                        <TextBlock Text="Endereço IP" Style="{StaticResource FiltLabel}"/>
                        <TextBox Text="{Binding IpFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FiltBox}" ToolTip="Substitui {IP} nos scripts"/>

                        <!-- Domain -->
                        <TextBlock Text="Domínio / FQDN" Style="{StaticResource FiltLabel}"/>
                        <TextBox Text="{Binding DomainFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FiltBox}" ToolTip="Substitui {DOMAIN} nos scripts"/>

                        <!-- Hash -->
                        <TextBlock Text="Hash (SHA256 / MD5)" Style="{StaticResource FiltLabel}"/>
                        <TextBox Text="{Binding HashFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FiltBox}"
                                 FontFamily="Consolas" FontSize="10"
                                 ToolTip="Substitui {HASH} nos scripts"/>

                        <!-- User -->
                        <TextBlock Text="Usuário" Style="{StaticResource FiltLabel}"/>
                        <TextBox Text="{Binding UserFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FiltBox}" ToolTip="Substitui {USER} nos scripts"/>

                        <!-- Process -->
                        <TextBlock Text="Processo" Style="{StaticResource FiltLabel}"/>
                        <TextBox Text="{Binding ProcessFilter, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FiltBox}" ToolTip="Substitui {PROCESS} nos scripts"/>

                        <!-- Searching indicator -->
                        <TextBlock Text="⟳  Buscando host…"
                                   Foreground="{DynamicResource Brush.Accent}" FontSize="10"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding IsSearchingHost, Converter={StaticResource BoolVis}}"/>

                        <Separator Margin="0,12,0,2" Background="{DynamicResource Brush.Stroke}"/>

                        <!-- Script catalog header -->
                        <TextBlock Style="{StaticResource SideHead}"
                                   Foreground="{DynamicResource Brush.Accent}">
                            📚  CATÁLOGO DE SCRIPTS
                        </TextBlock>
                        <TextBlock Style="{StaticResource Dim}" FontSize="9" TextWrapping="Wrap"
                                   Margin="0,0,0,8">
                            Scripts derivados dos repositórios públicos CrowdStrike.
                            Filtros acima parametrizam {HOST}/{IP}/{HASH}/{USER}/{PROCESS}.
                        </TextBlock>

                        <!-- Reconhecimento -->
                        <TextBlock Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,4,0,3">
                            🔍  Reconhecimento do Sistema
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding ScriptsRecon}"
                                      ItemTemplate="{StaticResource ScriptItemLow}"/>

                        <!-- Persistência -->
                        <TextBlock Foreground="{DynamicResource Brush.Warn}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,6,0,3">
                            ⏰  Persistência e Autoinício
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding ScriptsPersistencia}"
                                      ItemTemplate="{StaticResource ScriptItemMed}"/>

                        <!-- Usuários -->
                        <TextBlock Foreground="{DynamicResource Brush.Accent}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,6,0,3">
                            👤  Usuários e Credenciais
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding ScriptsUsuarios}"
                                      ItemTemplate="{StaticResource ScriptItemLow}"/>

                        <!-- Forense -->
                        <TextBlock Foreground="{DynamicResource Brush.Accent2}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,6,0,3">
                            🔬  Artefatos Forenses
                        </TextBlock>
                        <ItemsControl ItemsSource="{Binding ScriptsForense}"
                                      ItemTemplate="{StaticResource ScriptItemLow}"/>

                        <!-- Coleta — HIGH RISK -->
                        <TextBlock Foreground="{DynamicResource Brush.Danger}"
                                   FontWeight="SemiBold" FontSize="10" Margin="0,6,0,1">
                            💾  Coleta de Evidências
                        </TextBlock>
                        <TextBlock Text="⚠ Alto risco — modifica o sistema" FontSize="9"
                                   Foreground="{DynamicResource Brush.Danger}" Margin="0,0,0,3"/>
                        <ItemsControl ItemsSource="{Binding ScriptsColeta}"
                                      ItemTemplate="{StaticResource ScriptItemHigh}"/>

                        <Border Height="20"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- GridSplitter -->
            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource Brush.Stroke}" Cursor="SizeWE"/>

            <!-- ── Terminal area ──────────────────────────────────────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Terminal output -->
                <Border Grid.Row="0" Background="#080B15" CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1">
                    <ScrollViewer x:Name="TerminalScroll"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="TerminalOutput"
                                      ItemsSource="{Binding Terminal}"
                                      Padding="14,10"
                                      Background="Transparent"
                                      Focusable="False">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Text}"
                                               Foreground="{Binding Fore}"
                                               Style="{StaticResource TermLine}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Border>

                <!-- Busy overlay pill -->
                <Border Grid.Row="0"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Bottom"
                        Background="#CC080B15" CornerRadius="6" Margin="0,0,0,10" Padding="12,5">
                    <TextBlock Text="⟳  Aguardando Falcon API…"
                               Foreground="{DynamicResource Brush.Accent}"
                               FontFamily="Consolas" FontSize="12"/>
                </Border>

                <!-- Command input bar -->
                <Border Grid.Row="1" Background="#080B15" CornerRadius="8"
                        BorderBrush="{DynamicResource Brush.Stroke}" BorderThickness="1"
                        Margin="0,4,0,0" Padding="10,7">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Left"
                                   Text="PS ❯"
                                   FontFamily="Consolas" FontSize="13" FontWeight="SemiBold"
                                   Foreground="#40E0FF" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button Content="↵  Executar"
                                    Command="{Binding SendCommand}"
                                    IsEnabled="{Binding IsConnected}"
                                    Style="{StaticResource BtnPrimary}"
                                    Margin="8,0,0,0" Padding="14,5"/>
                            <Button Content="🗑"
                                    Command="{Binding ClearTerminalCommand}"
                                    Style="{StaticResource BtnGhost}"
                                    ToolTip="Limpar terminal"
                                    Margin="5,0,0,0" Padding="8,5"/>
                        </StackPanel>
                        <TextBox x:Name="CmdInput"
                                 Text="{Binding CommandInput, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding IsConnected}"
                                 Background="Transparent" Foreground="#E2E8FF"
                                 CaretBrush="#40E0FF" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="13"
                                 VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
